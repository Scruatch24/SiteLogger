<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= I18n.t("user_mailer.activity_digest.subject", month: @stats[:month_name]) %></title>
</head>
<body style="margin:0;padding:0;background:#f5f5f5;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f5f5f5;padding:40px 20px;">
    <tr><td align="center">
      <table width="560" cellpadding="0" cellspacing="0" style="background:#ffffff;border:2px solid #000000;border-radius:16px;overflow:hidden;box-shadow:4px 4px 0px 0px rgba(0,0,0,1);">

        <!-- Header -->
        <tr>
          <td style="background:#000000;padding:28px 32px;">
            <p style="margin:0;font-size:22px;font-weight:900;color:#ffffff;text-transform:uppercase;letter-spacing:-0.03em;">
              TALK<span style="color:#ea580c;">INVOICE</span>
            </p>
            <p style="margin:6px 0 0;font-size:10px;font-weight:900;color:#9ca3af;text-transform:uppercase;letter-spacing:0.15em;">
              <%= I18n.t("user_mailer.activity_digest.header") %>
            </p>
          </td>
        </tr>

        <!-- Body -->
        <tr>
          <td style="padding:32px;">
            <p style="margin:0 0 6px;font-size:12px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.1em;">
              <%= I18n.t("user_mailer.activity_digest.greeting", name: @user.profile&.business_name.presence || @user.email.split("@").first) %>
            </p>
            <h1 style="margin:0 0 24px;font-size:28px;font-weight:900;color:#000000;line-height:1.1;">
              <%= @stats[:month_name] %> <%= I18n.t("user_mailer.activity_digest.summary") %>
            </h1>

            <!-- Stats Grid -->
            <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
              <tr>
                <td width="48%" style="background:#fff7ed;border:2px solid #000;border-radius:12px;padding:18px;box-shadow:3px 3px 0px 0px rgba(0,0,0,1);">
                  <p style="margin:0 0 4px;font-size:9px;font-weight:900;color:#9ca3af;text-transform:uppercase;letter-spacing:0.12em;"><%= I18n.t("user_mailer.activity_digest.invoices_created") %></p>
                  <p style="margin:0;font-size:32px;font-weight:900;color:#ea580c;"><%= @stats[:invoices_created] %></p>
                </td>
                <td width="4%"></td>
                <td width="48%" style="background:#f0fdf4;border:2px solid #000;border-radius:12px;padding:18px;box-shadow:3px 3px 0px 0px rgba(0,0,0,1);">
                  <p style="margin:0 0 4px;font-size:9px;font-weight:900;color:#9ca3af;text-transform:uppercase;letter-spacing:0.12em;"><%= I18n.t("user_mailer.activity_digest.total_billed") %></p>
                  <p style="margin:0;font-size:32px;font-weight:900;color:#16a34a;"><%= @currency_sym %><%= number_with_delimiter(@stats[:total_billed].round(2)) %></p>
                </td>
              </tr>
              <tr><td colspan="3" style="height:12px;"></td></tr>
              <tr>
                <td width="48%" style="background:#fef2f2;border:2px solid #000;border-radius:12px;padding:18px;box-shadow:3px 3px 0px 0px rgba(0,0,0,1);">
                  <p style="margin:0 0 4px;font-size:9px;font-weight:900;color:#9ca3af;text-transform:uppercase;letter-spacing:0.12em;"><%= I18n.t("user_mailer.activity_digest.overdue") %></p>
                  <p style="margin:0;font-size:32px;font-weight:900;color:#dc2626;"><%= @stats[:overdue_count] %></p>
                </td>
                <td width="4%"></td>
                <td width="48%" style="background:#eff6ff;border:2px solid #000;border-radius:12px;padding:18px;box-shadow:3px 3px 0px 0px rgba(0,0,0,1);">
                  <p style="margin:0 0 4px;font-size:9px;font-weight:900;color:#9ca3af;text-transform:uppercase;letter-spacing:0.12em;"><%= I18n.t("user_mailer.activity_digest.paid_invoices") %></p>
                  <p style="margin:0;font-size:32px;font-weight:900;color:#2563eb;"><%= @stats[:paid_count] %></p>
                </td>
              </tr>
            </table>

            <!-- CTA -->
            <table width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td align="center">
                  <a href="<%= history_url %>" style="display:inline-block;background:#ea580c;color:#ffffff;font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:0.12em;padding:14px 32px;border-radius:12px;border:2px solid #000;box-shadow:3px 3px 0px 0px rgba(0,0,0,1);text-decoration:none;">
                    <%= I18n.t("user_mailer.activity_digest.view_history") %>
                  </a>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="background:#f9fafb;border-top:2px solid #e5e7eb;padding:20px 32px;">
            <p style="margin:0;font-size:10px;font-weight:700;color:#9ca3af;text-align:center;">
              © <%= Date.current.year %> TalkInvoice &nbsp;·&nbsp; <%= I18n.t("user_mailer.activity_digest.footer") %>
            </p>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
