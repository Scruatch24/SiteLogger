<div style="text-align: center;">
  <h2 style="margin: 0 0 8px 0; font-family: sans-serif; font-size: 22px; font-weight: 900; text-transform: uppercase; letter-spacing: -0.02em; color: #000000;">
    <%= I18n.t('user_mailer.welcome.header', locale: @locale) %>
  </h2>

  <p style="margin: 0 0 28px 0; font-family: sans-serif; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #9ca3af;">
    <%= I18n.t('user_mailer.welcome.tagline', locale: @locale) %>
  </p>

  <p style="margin: 0 0 24px 0; font-family: sans-serif; font-size: 16px; line-height: 1.6; color: #374151;">
    <%= I18n.t('user_mailer.welcome.body', locale: @locale) %>
  </p>

  <!-- Quick-start steps -->
  <table align="center" border="0" cellpadding="0" cellspacing="0" role="presentation" style="width: 100%; margin: 0 0 28px 0;">
    <tr>
      <td style="padding: 16px; background: #fff7ed; border: 2px solid #000000; border-radius: 16px;">
        <table border="0" cellpadding="0" cellspacing="0" role="presentation" style="width: 100%;">
          <tr>
            <td style="padding: 8px 0; font-family: sans-serif; font-size: 14px; color: #374151; border-bottom: 1px solid #fed7aa;">
              <span style="display: inline-block; width: 28px; height: 28px; line-height: 28px; text-align: center; background: #ea580c; color: #fff; border-radius: 8px; font-weight: 900; font-size: 12px; margin-right: 10px; vertical-align: middle;">1</span>
              <strong style="color: #000;"><%= I18n.t('user_mailer.welcome.step_1', locale: @locale) %></strong>
            </td>
          </tr>
          <tr>
            <td style="padding: 8px 0; font-family: sans-serif; font-size: 14px; color: #374151; border-bottom: 1px solid #fed7aa;">
              <span style="display: inline-block; width: 28px; height: 28px; line-height: 28px; text-align: center; background: #ea580c; color: #fff; border-radius: 8px; font-weight: 900; font-size: 12px; margin-right: 10px; vertical-align: middle;">2</span>
              <strong style="color: #000;"><%= I18n.t('user_mailer.welcome.step_2', locale: @locale) %></strong>
            </td>
          </tr>
          <tr>
            <td style="padding: 8px 0; font-family: sans-serif; font-size: 14px; color: #374151;">
              <span style="display: inline-block; width: 28px; height: 28px; line-height: 28px; text-align: center; background: #ea580c; color: #fff; border-radius: 8px; font-weight: 900; font-size: 12px; margin-right: 10px; vertical-align: middle;">3</span>
              <strong style="color: #000;"><%= I18n.t('user_mailer.welcome.step_3', locale: @locale) %></strong>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <div style="margin: 32px 0;">
    <a href="<%= root_url %>" class="btn" style="display: inline-block; padding: 16px 32px; background-color: #ea580c; color: #ffffff; text-decoration: none; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; border: 2px solid #000000; border-radius: 12px; box-shadow: 4px 4px 0px 0px #000000; font-family: sans-serif; font-size: 14px;">
      <%= I18n.t('user_mailer.welcome.cta', locale: @locale) %>
    </a>
  </div>

  <p style="margin: 0 0 8px 0; font-family: sans-serif; font-size: 14px; line-height: 1.6; color: #6b7280;">
    <%= I18n.t('user_mailer.welcome.help', locale: @locale) %>
  </p>

  <p style="margin: 0; font-family: sans-serif; font-size: 14px; color: #374151;">— <span style="font-weight: 900; color: #000000;">Talk</span><span style="font-weight: 900; color: #ea580c;">Invoice</span> Team</p>
</div>
