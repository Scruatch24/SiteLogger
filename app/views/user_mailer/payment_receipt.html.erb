<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= I18n.t("user_mailer.payment_receipt.subject") %></title>
</head>
<body style="margin:0;padding:0;background:#f5f5f5;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f5f5f5;padding:40px 20px;">
    <tr><td align="center">
      <table width="560" cellpadding="0" cellspacing="0" style="background:#ffffff;border:2px solid #000000;border-radius:16px;overflow:hidden;box-shadow:4px 4px 0px 0px rgba(0,0,0,1);">

        <!-- Header -->
        <tr>
          <td style="background:#000000;padding:28px 32px;">
            <p style="margin:0;font-size:22px;font-weight:900;color:#ffffff;text-transform:uppercase;letter-spacing:-0.03em;">
              TALK<span style="color:#ea580c;">INVOICE</span>
            </p>
            <p style="margin:6px 0 0;font-size:10px;font-weight:900;color:#9ca3af;text-transform:uppercase;letter-spacing:0.15em;">
              <%= I18n.t("user_mailer.payment_receipt.header") %>
            </p>
          </td>
        </tr>

        <!-- Green checkmark banner -->
        <tr>
          <td style="background:#f0fdf4;border-bottom:2px solid #e5e7eb;padding:20px 32px;text-align:center;">
            <span style="display:inline-block;width:48px;height:48px;background:#16a34a;border-radius:50%;border:2px solid #000;line-height:44px;font-size:24px;color:#fff;font-weight:900;">✓</span>
            <p style="margin:10px 0 0;font-size:14px;font-weight:900;color:#16a34a;text-transform:uppercase;letter-spacing:0.08em;">
              <%= I18n.t("user_mailer.payment_receipt.success") %>
            </p>
          </td>
        </tr>

        <!-- Body -->
        <tr>
          <td style="padding:32px;">
            <p style="margin:0 0 6px;font-size:12px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.1em;">
              <%= I18n.t("user_mailer.payment_receipt.greeting", name: @user.profile&.business_name.presence || @user.email.split("@").first) %>
            </p>
            <p style="margin:0 0 24px;font-size:15px;font-weight:700;color:#374151;line-height:1.5;">
              <%= I18n.t("user_mailer.payment_receipt.body", plan: @plan_name) %>
            </p>

            <!-- Receipt table -->
            <table width="100%" cellpadding="0" cellspacing="0" style="border:2px solid #000;border-radius:12px;overflow:hidden;margin-bottom:24px;box-shadow:3px 3px 0px 0px rgba(0,0,0,1);">
              <tr style="background:#f9fafb;border-bottom:1px solid #e5e7eb;">
                <td style="padding:12px 16px;font-size:10px;font-weight:900;color:#9ca3af;text-transform:uppercase;letter-spacing:0.1em;"><%= I18n.t("user_mailer.payment_receipt.plan") %></td>
                <td style="padding:12px 16px;font-size:12px;font-weight:900;color:#000;text-align:right;"><%= @plan_name %></td>
              </tr>
              <tr style="background:#ffffff;border-bottom:1px solid #e5e7eb;">
                <td style="padding:12px 16px;font-size:10px;font-weight:900;color:#9ca3af;text-transform:uppercase;letter-spacing:0.1em;"><%= I18n.t("user_mailer.payment_receipt.amount") %></td>
                <td style="padding:12px 16px;font-size:16px;font-weight:900;color:#16a34a;text-align:right;"><%= @currency_sym %><%= "%.2f" % @amount.to_f %> <%= @currency %></td>
              </tr>
              <tr style="background:#f9fafb;">
                <td style="padding:12px 16px;font-size:10px;font-weight:900;color:#9ca3af;text-transform:uppercase;letter-spacing:0.1em;"><%= I18n.t("user_mailer.payment_receipt.transaction_id") %></td>
                <td style="padding:12px 16px;font-size:11px;font-weight:700;color:#6b7280;text-align:right;font-family:monospace;"><%= @transaction_id %></td>
              </tr>
            </table>

            <!-- CTA -->
            <table width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td align="center">
                  <a href="<%= subscription_url %>" style="display:inline-block;background:#ea580c;color:#ffffff;font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:0.12em;padding:14px 32px;border-radius:12px;border:2px solid #000;box-shadow:3px 3px 0px 0px rgba(0,0,0,1);text-decoration:none;">
                    <%= I18n.t("user_mailer.payment_receipt.cta") %>
                  </a>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="background:#f9fafb;border-top:2px solid #e5e7eb;padding:20px 32px;">
            <p style="margin:0;font-size:10px;font-weight:700;color:#9ca3af;text-align:center;">
              © <%= Date.current.year %> TalkInvoice &nbsp;·&nbsp; <%= I18n.t("user_mailer.payment_receipt.footer") %>
            </p>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
