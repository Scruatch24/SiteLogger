<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= I18n.t("user_mailer.subscription_canceled.subject") %></title>
</head>
<body style="margin:0;padding:0;background:#f5f5f5;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f5f5f5;padding:40px 20px;">
    <tr><td align="center">
      <table width="560" cellpadding="0" cellspacing="0" style="background:#ffffff;border:2px solid #000000;border-radius:16px;overflow:hidden;box-shadow:4px 4px 0px 0px rgba(0,0,0,1);">

        <!-- Header -->
        <tr>
          <td style="background:#000000;padding:28px 32px;">
            <p style="margin:0;font-size:22px;font-weight:900;color:#ffffff;text-transform:uppercase;letter-spacing:-0.03em;">
              TALK<span style="color:#ea580c;">INVOICE</span>
            </p>
            <p style="margin:6px 0 0;font-size:10px;font-weight:900;color:#9ca3af;text-transform:uppercase;letter-spacing:0.15em;">
              <%= I18n.t("user_mailer.subscription_canceled.header") %>
            </p>
          </td>
        </tr>

        <!-- Body -->
        <tr>
          <td style="padding:32px;">
            <p style="margin:0 0 6px;font-size:12px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.1em;">
              <%= I18n.t("user_mailer.subscription_canceled.greeting", name: @user.profile&.business_name.presence || @user.email.split("@").first) %>
            </p>
            <h1 style="margin:0 0 16px;font-size:26px;font-weight:900;color:#000000;line-height:1.1;">
              <%= I18n.t("user_mailer.subscription_canceled.title") %>
            </h1>

            <% if @ends_at.present? %>
            <div style="background:#fff7ed;border:2px solid #ea580c;border-radius:12px;padding:14px 18px;margin-bottom:20px;">
              <p style="margin:0;font-size:12px;font-weight:900;color:#ea580c;text-transform:uppercase;letter-spacing:0.08em;">
                <%= I18n.t("user_mailer.subscription_canceled.access_until", date: @ends_at.strftime("%B %d, %Y")) %>
              </p>
            </div>
            <% end %>

            <p style="margin:0 0 16px;font-size:14px;font-weight:700;color:#374151;line-height:1.6;">
              <%= I18n.t("user_mailer.subscription_canceled.body") %>
            </p>

            <p style="margin:0 0 24px;font-size:13px;font-weight:700;color:#6b7280;line-height:1.5;">
              <%= I18n.t("user_mailer.subscription_canceled.reactivate_hint") %>
            </p>

            <!-- CTA -->
            <table width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td align="center">
                  <a href="<%= pricing_url %>" style="display:inline-block;background:#ea580c;color:#ffffff;font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:0.12em;padding:14px 32px;border-radius:12px;border:2px solid #000;box-shadow:3px 3px 0px 0px rgba(0,0,0,1);text-decoration:none;">
                    <%= I18n.t("user_mailer.subscription_canceled.cta") %>
                  </a>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="background:#f9fafb;border-top:2px solid #e5e7eb;padding:20px 32px;">
            <p style="margin:0;font-size:10px;font-weight:700;color:#9ca3af;text-align:center;">
              © <%= Date.current.year %> TalkInvoice &nbsp;·&nbsp; <%= I18n.t("user_mailer.subscription_canceled.footer") %>
            </p>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
