<div class="flex items-center gap-3 pt-2">
  <!-- Plus Button with Dropup -->
  <div class="relative">
    <button type="button" id="addMenuBtn" data-nosnippet onclick="toggleAddMenu(this)" class="w-12 h-12 border-2 border-black rounded-xl text-3xl font-black text-black hover:bg-gray-50 transition-all flex items-center justify-center add-menu-btn active:scale-95 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[2px] active:translate-y-[2px]">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6" />
      </svg>
    </button>
    <div id="addMenuDropup" data-nosnippet class="hidden absolute bottom-full left-0 mb-2 bg-white border-2 border-black rounded-xl overflow-hidden min-w-[200px]">
      <button type="button" id="addLaborBtn" onclick="if(!this.disabled){addSectionWithScrollLock(addLaborSection);}" class="w-full px-4 py-3 text-left text-[10px] font-black uppercase tracking-widest transition-all border-b border-gray-200 md:hover:bg-orange-50 md:hover:text-orange-600 active:scale-95 active:pl-5 active:bg-orange-600 active:text-white flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13l9-9 3 3-9 9H3v-3z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4l8 8-4 4-8-8" />
        </svg>
        <span><%= t('add_labor') %></span>
      </button>
      <button type="button" id="addMaterialBtn" onclick="if(!this.disabled){addSectionWithScrollLock(addMaterialSection);}" class="w-full px-4 py-3 text-left text-[10px] font-black uppercase tracking-widest transition-all border-b border-gray-200 md:hover:bg-orange-50 md:hover:text-orange-600 active:scale-95 active:pl-5 active:bg-orange-600 active:text-white flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 7l8-4 8 4v10l-8 4-8-4z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 7l8 4 8-4" />
        </svg>
        <span><%= t('add_material') %></span>
      </button>
      <button type="button" id="addExpenseBtn" onclick="if(!this.disabled){addSectionWithScrollLock(addExpenseSection);}" class="w-full px-4 py-3 text-left text-[10px] font-black uppercase tracking-widest transition-all border-b border-gray-200 md:hover:bg-red-50 md:hover:text-red-600 active:scale-95 active:pl-5 active:bg-orange-600 active:text-white flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-2 0-3.5 1.1-3.5 2.5S10 13 12 13s3.5 1.1 3.5 2.5S14 18 12 18m0-10V6m0 12v-2m0-10c1.5 0 2.75.5 3.6 1.3m-7.2 0C9.25 6.5 10.5 6 12 6m-6 6a8 8 0 1116 0 8 8 0 01-16 0z" />
        </svg>
        <span><%= t('add_expense') %></span>
      </button>
      <button type="button" id="addFeeBtn" onclick="if(!this.disabled){addSectionWithScrollLock(addFeeSection);}" class="w-full px-4 py-3 text-left text-[10px] font-black uppercase tracking-widest transition-all border-b border-gray-200 md:hover:bg-blue-50 md:hover:text-blue-500 active:scale-95 active:pl-5 active:bg-orange-600 active:text-white flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 17h1m8 0h1M9 7h6M5 12h14M7 21a2 2 0 01-2-2V5a2 2 0 012-2h10a2 2 0 012 2v14a2 2 0 01-2 2H7z" />
        </svg>
        <span><%= t('add_fee') %></span>
      </button>
      <button type="button" id="addCreditBtn" onclick="if(!this.disabled){addSectionWithScrollLock(addCreditSection);}" class="w-full px-4 py-3 text-left text-[10px] font-black uppercase tracking-widest transition-all md:hover:bg-red-50 md:hover:text-red-600 active:scale-95 active:pl-5 active:bg-orange-600 active:text-white flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m-7-7h14" />
        </svg>
        <span><%= t('add_credit') %></span>
      </button>
    </div>
  </div>
  
  <!-- Confirm Log Button (Centered/Expanded) -->
  <button id="saveButton" data-nosnippet type="button" onclick="setupSaveButton()" class="flex-1 h-12 bg-orange-600 hover:bg-orange-700 text-white border-2 border-black font-black rounded-xl uppercase text-[10px] tracking-widest transition-all active:scale-[0.98] flex items-center justify-center shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[2px] active:translate-y-[2px]">
    <%= t('create_pdf') %>
  </button>
</div>
