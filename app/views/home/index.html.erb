  window.operationLimit = <%= @profile.operation_limit %>;

  // ── FROM / BILLED TO State ──
  const decodeEntities = (str) => {
    const el = document.createElement('textarea');
    el.innerHTML = str;
    return el.value;
  };

  window.profileDefaults = {
    business_name: decodeEntities("<%= j @profile.business_name.to_s %>"),
    payment_instructions: decodeEntities("<%= j @profile.payment_instructions.to_s %>"),
    note: decodeEntities("<%= j @profile.note.to_s %>"),
    email: decodeEntities("<%= j @profile.email.to_s %>"),
    phone: decodeEntities("<%= j @profile.phone.to_s %>"),
    address: decodeEntities("<%= j @profile.address.to_s %>"),
    tax_id: decodeEntities("<%= j @profile.tax_id.to_s %>")
  };
  window.invoiceSenderInfo = null; // null = use profile defaults
  window.invoiceRecipientInfo = null; // null = no client selected

  // Character limit helpers for modals (same logic as profile page)
  function checkFromCharLimit(e, el, charMax, lineMax) {
    const lines = el.value.split('\n');
    const cursorPosition = el.selectionStart;
    let currentLineIndex = 0, charsCount = 0;
    for (let i = 0; i < lines.length; i++) {
      charsCount += lines[i].length + 1;
      if (cursorPosition < charsCount) { currentLineIndex = i; break; }
    }
    if (e.key === 'Enter') {
      if (lines.length >= lineMax) { e.preventDefault(); return false; }
    } else if (e.key.length === 1 && !e.ctrlKey && !e.metaKey && !e.altKey) {
      if (lines[currentLineIndex].length >= charMax) { e.preventDefault(); return false; }
    }
    return true;
  }

  function limitFromLinesAndChars(el, charMax, lineMax) {
    let lines = el.value.split('\n');
    let changed = false;
    if (lines.length > lineMax) { lines = lines.slice(0, lineMax); changed = true; }
    lines = lines.map(line => {
      if (line.length > charMax) { changed = true; return line.substring(0, charMax); }
      return line;
    });
    if (changed) {
      const start = el.selectionStart, end = el.selectionEnd;
      el.value = lines.join('\n');
      el.setSelectionRange(start, end);
    }
  }

  // ── FROM Modal Functions ──
  function openFromModal() {
    const src = window.invoiceSenderInfo || window.profileDefaults;
    document.getElementById('fromBusinessName').value = src.business_name || '';
    document.getElementById('fromPaymentInstructions').value = src.payment_instructions || '';
    document.getElementById('fromNote').value = src.note || '';
    document.getElementById('fromEmail').value = src.email || '';
    document.getElementById('fromPhone').value = src.phone || '';
    document.getElementById('fromAddress').value = src.address || '';
    document.getElementById('fromTaxId').value = src.tax_id || '';

    const modal = document.getElementById('fromModal');
    const overlay = document.getElementById('fromModalOverlay');
    const content = document.getElementById('fromModalContent');
    document.body.classList.add('overflow-hidden');
    modal.classList.remove('hidden');
    requestAnimationFrame(() => {
      overlay.classList.add('opacity-100');
      content.classList.remove('translate-y-full', 'md:translate-y-1/2', 'md:scale-95', 'md:opacity-0');
      content.classList.add('translate-y-0', 'md:translate-y-[-50%]', 'md:scale-100', 'md:opacity-100');
    });
  }

  function closeFromModal() {
    const overlay = document.getElementById('fromModalOverlay');
    const content = document.getElementById('fromModalContent');
    overlay.classList.remove('opacity-100');
    content.classList.add('translate-y-full', 'md:translate-y-1/2', 'md:scale-95', 'md:opacity-0');
    content.classList.remove('translate-y-0', 'md:translate-y-[-50%]', 'md:scale-100', 'md:opacity-100');
    setTimeout(() => {
      document.getElementById('fromModal').classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
    }, 300);
  }

  function saveFromModal() {
    window.invoiceSenderInfo = {
      business_name: document.getElementById('fromBusinessName').value.trim(),
      payment_instructions: document.getElementById('fromPaymentInstructions').value.trim(),
      note: document.getElementById('fromNote').value.trim(),
      email: document.getElementById('fromEmail').value.trim(),
      phone: document.getElementById('fromPhone').value.trim(),
      address: document.getElementById('fromAddress').value.trim(),
      tax_id: document.getElementById('fromTaxId').value.trim()
    };
    // Update display
    const display = document.getElementById('fromFieldDisplay');
    if (display) {
      display.textContent = window.invoiceSenderInfo.business_name || window.profileDefaults.business_name || '';
      display.classList.remove('text-gray-300');
      display.classList.add('text-black');
    }
    closeFromModal();
  }

  function resetFromToDefaults() {
    window.invoiceSenderInfo = null;
    document.getElementById('fromBusinessName').value = window.profileDefaults.business_name || '';
    document.getElementById('fromPaymentInstructions').value = window.profileDefaults.payment_instructions || '';
    document.getElementById('fromNote').value = window.profileDefaults.note || '';
    document.getElementById('fromEmail').value = window.profileDefaults.email || '';
    document.getElementById('fromPhone').value = window.profileDefaults.phone || '';
    document.getElementById('fromAddress').value = window.profileDefaults.address || '';
    document.getElementById('fromTaxId').value = window.profileDefaults.tax_id || '';
    // Update display
    const display = document.getElementById('fromFieldDisplay');
    if (display) {
      display.textContent = window.profileDefaults.business_name || '<%= js_t("from_placeholder") %>';
    }
  }

  // ── BILLED TO Modal Functions ──
  let billedToSearchTimeout = null;
  let billedToMode = 'select'; // 'select', 'existing', or 'add'

  function openBilledToModal() {
    const modal = document.getElementById('billedToModal');
    const overlay = document.getElementById('billedToModalOverlay');
    const content = document.getElementById('billedToModalContent');

    // Reset search
    const searchInput = document.getElementById('billedToSearch');
    if (searchInput) searchInput.value = '';

    // If we have a selected recipient, go straight to Screen 2
    if (window.invoiceRecipientInfo) {
      billedToMode = window.invoiceRecipientInfo.client_id ? 'existing' : 'add';
      showBilledToScreen2(window.invoiceRecipientInfo);
    } else if (!window.userSignedIn) {
      // Free users: skip search, go straight to Add Client form
      billedToMode = 'add';
      showBilledToScreen2({ client_id: null, name: '', email: '', phone: '', address: '', notes: '' });
    } else {
      showBilledToScreen1();
    }

    // Load initial client list (only for paid users)
    if (window.userSignedIn) searchBilledToClients('');

    document.body.classList.add('overflow-hidden');
    modal.classList.remove('hidden');
    requestAnimationFrame(() => {
      overlay.classList.add('opacity-100');
      content.classList.remove('translate-y-full', 'md:translate-y-1/2', 'md:scale-95', 'md:opacity-0');
      content.classList.add('translate-y-0', 'md:translate-y-[-50%]', 'md:scale-100', 'md:opacity-100');
    });
  }

  function closeBilledToModal() {
    const overlay = document.getElementById('billedToModalOverlay');
    const content = document.getElementById('billedToModalContent');
    overlay.classList.remove('opacity-100');
    content.classList.add('translate-y-full', 'md:translate-y-1/2', 'md:scale-95', 'md:opacity-0');
    content.classList.remove('translate-y-0', 'md:translate-y-[-50%]', 'md:scale-100', 'md:opacity-100');
    setTimeout(() => {
      document.getElementById('billedToModal').classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
    }, 300);
  }

  function showBilledToScreen1() {
    document.getElementById('billedToSearchSection').classList.remove('hidden');
    document.getElementById('billedToFields').classList.add('hidden');
    document.getElementById('billedToFooter').classList.add('hidden');
    document.getElementById('billedToFooter').classList.remove('flex');
  }

  function showBilledToScreen2(data) {
    // Hide search, show fields + footer
    document.getElementById('billedToSearchSection').classList.add('hidden');
    document.getElementById('billedToFields').classList.remove('hidden');
    document.getElementById('billedToFooter').classList.remove('hidden');
    document.getElementById('billedToFooter').classList.add('flex');

    // Populate fields
    document.getElementById('billedToName').value = data.name || '';
    document.getElementById('billedToEmail').value = data.email || '';
    document.getElementById('billedToPhone').value = data.phone || '';
    document.getElementById('billedToAddress').value = data.address || '';
    document.getElementById('billedToNotes').value = data.notes || '';

    if (data.client_id) {
      // Existing client: read-only with normal black text
      ['billedToName', 'billedToEmail', 'billedToPhone', 'billedToAddress'].forEach(id => {
        const el = document.getElementById(id);
        el.readOnly = true;
        el.classList.add('bg-gray-50');
        el.classList.remove('text-gray-500');
      });
      document.getElementById('billedToNotesGroup').classList.add('hidden');
    } else {
      // New client: editable
      ['billedToName', 'billedToEmail', 'billedToPhone', 'billedToAddress'].forEach(id => {
        const el = document.getElementById(id);
        el.readOnly = false;
        el.classList.remove('bg-gray-50', 'text-gray-500');
      });
      document.getElementById('billedToNotesGroup').classList.remove('hidden');
    }

    // Store temporary client_id
    document.getElementById('billedToName').dataset.clientId = data.client_id || '';
  }

  function goBackBilledTo() {
    showBilledToScreen1();
  }

  function searchBilledToClients(term) {
    clearTimeout(billedToSearchTimeout);
    billedToSearchTimeout = setTimeout(async () => {
      if (!window.userSignedIn) return;
      try {
        const res = await fetch('/clients/search?q=' + encodeURIComponent(term), {
          headers: { 'Accept': 'application/json' }
        });
        const clients = await res.json();
        renderBilledToClientList(clients);
      } catch (e) {
        console.error('[BilledTo] Search error:', e);
      }
    }, 200);
  }

  function renderBilledToClientList(clients) {
    const container = document.getElementById('billedToClientList');
    // Keep the "Add Client" button (first child)
    const addBtn = container.firstElementChild;
    container.innerHTML = '';
    container.appendChild(addBtn);

    clients.forEach(c => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-left hover:bg-gray-50 transition-colors';
      btn.onclick = () => selectBilledToClient(c);
      btn.innerHTML = `
        <div class="w-8 h-8 rounded-lg bg-gray-100 border border-gray-200 flex items-center justify-center flex-shrink-0">
          <span class="text-[10px] font-black text-gray-600">${(c.name || '').split(/\\s+/).map(w => w[0]).join('').toUpperCase().substring(0, 2)}</span>
        </div>
        <div class="min-w-0 flex-1">
          <span class="text-sm font-bold text-black block truncate">${c.name}</span>
          ${c.email ? '<span class="text-[10px] text-gray-400 block truncate">' + c.email + '</span>' : ''}
        </div>
        <span class="text-[9px] font-bold text-gray-300 uppercase flex-shrink-0">${c.invoices_count || 0} ${window.APP_LANGUAGES.inv_short || 'inv'}</span>
      `;
      container.appendChild(btn);
    });

    if (clients.length === 0) {
      const empty = document.createElement('p');
      empty.className = 'text-xs text-gray-400 font-bold text-center py-3';
      empty.textContent = window.APP_LANGUAGES.no_clients_found || '<%= js_t("no_clients_found") %>';
      container.appendChild(empty);
    }
  }

  function selectBilledToClient(client) {
    billedToMode = 'existing';
    showBilledToScreen2({
      client_id: client.id,
      name: client.name,
      email: client.email || '',
      phone: client.phone || '',
      address: client.address || '',
      notes: client.notes || ''
    });
  }

  function selectBilledToAddClient() {
    billedToMode = 'add';
    showBilledToScreen2({ client_id: null, name: '', email: '', phone: '', address: '', notes: '' });
    setTimeout(() => document.getElementById('billedToName').focus(), 50);
  }

  function clearBilledToSelection() {
    window.invoiceRecipientInfo = null;
    billedToMode = 'select';
    // Update display
    const display = document.getElementById('billedToFieldDisplay');
    if (display) {
      display.textContent = '<%= js_t("billed_to_placeholder") %>';
      display.classList.add('text-gray-300');
      display.classList.remove('text-black');
    }
    // Update hidden field
    document.getElementById('editClient').value = '';
    // Update client badge in PDF modal
    const clientBadge = document.getElementById('pdfClientText');
    if (clientBadge) clientBadge.textContent = '<%= js_t("no_client") %>';
  }

  function saveBilledToModal() {
    const name = document.getElementById('billedToName').value.trim();
    if (!name) {
      document.getElementById('billedToNameError').classList.remove('hidden');
      document.getElementById('billedToName').focus();
      return;
    }
    document.getElementById('billedToNameError').classList.add('hidden');

    window.invoiceRecipientInfo = {
      client_id: document.getElementById('billedToName').dataset.clientId || null,
      name: name,
      email: document.getElementById('billedToEmail').value.trim(),
      phone: document.getElementById('billedToPhone').value.trim(),
      address: document.getElementById('billedToAddress').value.trim(),
      notes: document.getElementById('billedToNotes').value.trim(),
      is_new: billedToMode === 'add'
    };

    // Update display
    const display = document.getElementById('billedToFieldDisplay');
    if (display) {
      display.textContent = name;
      display.classList.remove('text-gray-300');
      display.classList.add('text-black');
    }
    // Update hidden field for backward compat
    document.getElementById('editClient').value = name;
    // Update client badge in PDF modal
    const clientBadge = document.getElementById('pdfClientText');
    if (clientBadge) clientBadge.textContent = name;

    closeBilledToModal();
  }

  // Helper to programmatically set recipient (used by AI/updateUI)
  window.setRecipientInfo = function(info) {
    window.invoiceRecipientInfo = info;
    const display = document.getElementById('billedToFieldDisplay');
    if (display && info && info.name) {
      display.textContent = info.name;
      display.classList.remove('text-gray-300');
      display.classList.add('text-black');
    }
    document.getElementById('editClient').value = (info && info.name) || '';
  };

  // Helper to programmatically set sender (used by AI/updateUI)
  window.setSenderInfo = function(info) {
    window.invoiceSenderInfo = info;
    const display = document.getElementById('fromFieldDisplay');
    if (display && info && info.business_name) {
      display.textContent = info.business_name;
    }
  };

  // Initialize once on load
  document.addEventListener('DOMContentLoaded', () => {
    initGlobalVariables();
  });
  
</script>
