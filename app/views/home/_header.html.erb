<header class="flex flex-row justify-between items-center mb-8 md:mb-12 pt-2 px-1 gap-2">
  <div class="flex items-center gap-2 md:gap-4 select-none min-w-0">
    <div class="flex items-center justify-center w-11 h-11 md:w-14 md:h-14 bg-orange-600 border-2 border-black shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] rounded-xl shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6" />
      </svg>
    </div>
    <a href="/" class="text-2xl md:text-4xl font-black tracking-tighter text-black uppercase truncate leading-none pr-2">
      TALK<span class="text-orange-600">INVOICE</span>
    </a>
  </div>
  
  <div class="flex gap-1.5 md:gap-3 shrink-0" data-nosnippet>
    <%= link_to history_path, class: "p-1.5 md:p-2 bg-white border-2 border-black rounded-xl nav-link-hover transition-all group shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[1px] active:translate-y-[1px] #{request.path.start_with?('/history') ? 'nav-active' : ''}" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span class="nav-tooltip"><%= t('history') %></span>
    <% end %>

    <%= link_to profile_path, class: "p-1.5 md:p-2 bg-white border-2 border-black rounded-xl nav-link-hover transition-all group shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[1px] active:translate-y-[1px] #{request.path == '/profile' ? 'nav-active' : ''}" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      <span class="nav-tooltip"><%= t('profile') %></span>
    <% end %>

    <%= link_to settings_path, class: "p-1.5 md:p-2 bg-white border-2 border-black rounded-xl nav-link-hover transition-all group shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[1px] active:translate-y-[1px] #{request.path == '/settings' ? 'nav-active' : ''}" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <span class="nav-tooltip"><%= t('settings') %></span>
    <% end %>

    <% if user_signed_in? && current_user.profile&.ever_paid? %>
      <%= link_to subscription_path, class: "p-1.5 md:p-2 bg-orange-600 border-2 border-black rounded-xl nav-link-hover transition-all group shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[1px] active:translate-y-[1px] #{request.path.start_with?('/subscription') ? 'nav-active' : ''}" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
        </svg>
        <span class="nav-tooltip"><%= t('nav.subscription') %></span>
      <% end %>
    <% else %>
      <%= link_to pricing_path, class: "p-1.5 md:p-2 bg-orange-600 border-2 border-black rounded-xl nav-link-hover transition-all group shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[1px] active:translate-y-[1px] #{request.path.start_with?('/pricing') ? 'nav-active' : ''}" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6 text-white" fill="currentColor" viewBox="0 0 24 24" stroke="none">
          <path d="M12 2.4c.33 0 .63.2.76.5l1.87 4.34 4.64.36c.63.05.88.84.38 1.23l-3.55 3.05 1.06 4.44c.13.55-.44.98-.94.7L12 14.72l-4.22 2.3c-.5.28-1.07-.15-.94-.7l1.06-4.44-3.55-3.05c-.5-.39-.25-1.18.38-1.23l4.64-.36 1.87-4.34c.13-.3.43-.5.76-.5z" />
        </svg>
        <span class="nav-tooltip"><%= t('pricing') %></span>
      <% end %>
    <% end %>

    <% if user_signed_in? %>
      <%
        _notif_logs = current_user.logs.kept
        _overdue_notifs = _notif_logs.select { |l| l.current_status == "overdue" }.first(5)
        _due_soon_notifs = _notif_logs.select { |l|
          d = l.parsed_due_date
          s = l.current_status
          d && s != "paid" && s != "overdue" && d >= Date.today && d <= Date.today + 7
        }.first(5)
        _recently_paid = _notif_logs.select { |l|
          l.current_status == "paid" && l.paid_at.present? && l.paid_at >= 7.days.ago
        }.first(3)
        _sub_profile = current_user.profile
        _sub_events = []
        if _sub_profile&.paid? && _sub_profile.respond_to?(:current_period_end) && _sub_profile.current_period_end.present?
          _days_left = (_sub_profile.current_period_end.to_date - Date.today).to_i
          if _days_left <= 7 && _days_left >= 0
            _sub_events << { days: _days_left }
          end
        end
        _notif_count = _overdue_notifs.size + _due_soon_notifs.size + _recently_paid.size + _sub_events.size
      %>
      <div class="relative" id="notifWrap">
        <button type="button" onclick="toggleNotifDropdown()" class="p-1.5 md:p-2 bg-white border-2 border-black rounded-xl nav-link-hover transition-all group shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[1px] active:translate-y-[1px]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
          <% if _notif_count > 0 %>
            <span class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 border border-black rounded-full text-[8px] font-black text-white flex items-center justify-center"><%= _notif_count > 9 ? '9+' : _notif_count %></span>
          <% end %>
          <span class="nav-tooltip"><%= t('notifications', default: 'Notifications') %></span>
        </button>
        <div id="notifDropdown" class="hidden absolute top-full right-0 mt-2 w-72 md:w-80 bg-white border-2 border-black rounded-xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] z-[300] overflow-hidden">
          <div class="px-4 py-3 border-b-2 border-black bg-gray-50 flex items-center justify-between">
            <span class="text-[10px] font-black uppercase tracking-widest"><%= t('notifications', default: 'Notifications') %></span>
            <span class="text-[9px] font-bold text-gray-400"><%= _notif_count %></span>
          </div>
          <div class="max-h-72 overflow-y-auto custom-scrollbar">
            <% if _notif_count == 0 %>
              <div class="px-4 py-6 text-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto text-gray-200 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
                <p class="text-[10px] font-bold text-gray-400 uppercase"><%= t('no_notifications', default: 'All caught up!') %></p>
              </div>
            <% else %>
              <% _overdue_notifs.each do |log| %>
                <div class="px-4 py-2.5 border-b border-gray-100 flex items-start gap-2.5 hover:bg-red-50 transition-colors">
                  <div class="w-6 h-6 rounded-lg bg-red-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg class="w-3.5 h-3.5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-[10px] font-black text-red-700 uppercase"><%= t('overdue') %></p>
                    <p class="text-xs font-bold text-gray-800 truncate">INV-<%= log.display_number %> · <%= log.client.to_s.strip.presence || t('unknown_client') %></p>
                    <% if log.parsed_due_date %>
                      <p class="text-[9px] font-bold text-gray-400"><%= (Date.today - log.parsed_due_date).to_i %> <%= t('days_overdue_suffix', default: 'days overdue') %></p>
                    <% end %>
                  </div>
                </div>
              <% end %>
              <% _due_soon_notifs.each do |log| %>
                <div class="px-4 py-2.5 border-b border-gray-100 flex items-start gap-2.5 hover:bg-amber-50 transition-colors">
                  <div class="w-6 h-6 rounded-lg bg-amber-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg class="w-3.5 h-3.5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" d="M12 6v6l4 2"/></svg>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-[10px] font-black text-amber-700 uppercase"><%= t('due_soon_label', default: 'Due Soon') %></p>
                    <p class="text-xs font-bold text-gray-800 truncate">INV-<%= log.display_number %> · <%= log.client.to_s.strip.presence || t('unknown_client') %></p>
                    <p class="text-[9px] font-bold text-gray-400"><%= log.parsed_due_date&.strftime("%b %d") %></p>
                  </div>
                </div>
              <% end %>
              <% _recently_paid.each do |log| %>
                <div class="px-4 py-2.5 border-b border-gray-100 flex items-start gap-2.5 hover:bg-green-50 transition-colors">
                  <div class="w-6 h-6 rounded-lg bg-green-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg class="w-3.5 h-3.5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-[10px] font-black text-green-700 uppercase"><%= t('payment_received', default: 'Payment Received') %></p>
                    <p class="text-xs font-bold text-gray-800 truncate">INV-<%= log.display_number %> · <%= log.client.to_s.strip.presence || t('unknown_client') %></p>
                    <p class="text-[9px] font-bold text-gray-400"><%= log.paid_at&.strftime("%b %d") %></p>
                  </div>
                </div>
              <% end %>
              <% _sub_events.each do |ev| %>
                <div class="px-4 py-2.5 border-b border-gray-100 flex items-start gap-2.5 hover:bg-blue-50 transition-colors">
                  <div class="w-6 h-6 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg class="w-3.5 h-3.5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-[10px] font-black text-blue-700 uppercase"><%= t('subscription_renewal', default: 'Subscription') %></p>
                    <p class="text-xs font-bold text-gray-800"><%= t('plan_renews_in', days: ev[:days], default: "Pro plan renews in %{days} days") %></p>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <% if user_signed_in? %>
      <button type="button" onclick="window.showLogoutModal()" class="p-1.5 md:p-2 bg-white border-2 border-black rounded-xl nav-link-hover transition-all group shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[1px] active:translate-y-[1px]">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="h-5 w-5 md:h-6 md:w-6 text-black group-hover:text-red-600">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5.636 5.636a9 9 0 1012.728 0M12 3v9" />
        </svg>
        <span class="nav-tooltip"><%= t('log_out') %></span>
      </button>
    <% else %>
      <%= link_to new_user_session_path, class: "p-1.5 md:p-2 bg-white border-2 border-black rounded-xl nav-link-hover transition-all group shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[1px] active:translate-y-[1px]" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="h-5 w-5 md:h-6 md:w-6 text-black group-hover:text-orange-600">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
        </svg>
        <span class="nav-tooltip"><%= t('sign_in') %></span>
      <% end %>
    <% end %>
  </div>
</header>
<script>
  function toggleNotifDropdown() {
    var dd = document.getElementById('notifDropdown');
    if (dd) dd.classList.toggle('hidden');
  }
  document.addEventListener('click', function(e) {
    if (!e.target.closest('#notifWrap')) {
      var dd = document.getElementById('notifDropdown');
      if (dd) dd.classList.add('hidden');
    }
  });
</script>
